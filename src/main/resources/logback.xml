<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%date %-5level %-38(%logger{36}) -- %-82(%msg)  [%thread]%n</pattern>
    </encoder>
  </appender>

  <!--
    Default root level is INFO. Command-line tools (e.g. CredentialGenerator)
    inherit this. The role services (Registrar/MASA/Pledge) override per-package
    levels at startup via LoggerInitializer based on their -v verbosity flags.
  -->
  <root level="info">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>